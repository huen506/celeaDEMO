          "voiceClipKey": "",
          "isInnerThought": false,
          "portraitFocusSlot": 1
        },
        {
          "speakerId": "draven",
          "speakerDisplayName": "",
          "text": "（她說得很自然。好像在這裡待很久了。）",
          "voiceClipKey": "",
          "isInnerThought": true,
          "portraitFocusSlot": 0
        }
      ],
      "hasChoice": true,
      "choices": [
        {
          "choiceId": "C001_A",
          "text": "有趣。這種人最容易死在自己嘴巴上。",
          "choiceCategory": 2,
          "payloadKey": "choice_sin_observe"
        },
        {
          "choiceId": "C001_B",
          "text": "算了。今天不是為了這種事流血的日子。",
